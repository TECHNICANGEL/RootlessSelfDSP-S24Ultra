<?xml version="1.0" encoding="utf-8"?>
<!-- S24 ULTRA - Switch Group Preference -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="56dp"
    android:gravity="center_vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingVertical="8dp"
    android:background="@color/ultra_glass_bg"
    android:foreground="@drawable/ripple_rounded"
    android:clipToPadding="false"
    android:baselineAligned="false">

    <LinearLayout
        android:id="@+id/icon_frame"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="32dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:layout_marginEnd="12dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@android:id/icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            app:maxWidth="24dp"
            app:maxHeight="24dp"
            app:tint="@color/ultra_primary_light"/>

    </LinearLayout>

    <RelativeLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:paddingVertical="8dp">

        <TextView
            android:id="@android:id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:textColor="@color/ultra_text_primary"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium"
            android:ellipsize="marquee"
            tools:text="Title" />

        <TextView
            android:id="@android:id/summary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@android:id/title"
            android:layout_alignStart="@android:id/title"
            android:layout_marginTop="2dp"
            android:layout_gravity="start"
            android:textAlignment="viewStart"
            android:textColor="@color/ultra_text_tertiary"
            android:textSize="12sp"
            android:maxLines="10"
            style="@style/PreferenceSummaryTextStyle"
            tools:text="Summary"
            tools:ignore="PrivateResource" />

    </RelativeLayout>

    <!-- Preference should place its actual preference widget here. -->
    <LinearLayout
        android:id="@android:id/widget_frame"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:gravity="end|center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="0dp"
        android:orientation="vertical"/>

</LinearLayout>