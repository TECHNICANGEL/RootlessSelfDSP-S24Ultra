<?xml version="1.0" encoding="utf-8"?>
<!-- S24 ULTRA - Premium Widget Design -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="4dp"
    android:background="@drawable/widget_background_ultra">

    <!-- Main content container with glassmorphism effect -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="8dp">

        <!-- Power icon with glow effect -->
        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:layout_weight="1">

            <ImageView
                android:id="@+id/widget_engine_icon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="12dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_engine_off"
                android:contentDescription="@string/widget_engine_toggle_description" />

            <!-- Loading indicator overlay -->
            <ProgressBar
                android:id="@+id/widget_progress"
                style="?android:attr/progressBarStyleSmall"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:visibility="gone"
                android:indeterminate="true"
                android:indeterminateTint="@color/ultra_accent" />
        </FrameLayout>

        <!-- Status text -->
        <TextView
            android:id="@+id/widget_status_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/widget_status_off"
            android:textColor="@color/widget_text_color"
            android:textSize="10sp"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:ellipsize="end"
            tools:text="DSP OFF" />

    </LinearLayout>

</FrameLayout>