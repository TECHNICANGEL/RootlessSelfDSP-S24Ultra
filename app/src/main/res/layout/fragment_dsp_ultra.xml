<?xml version="1.0" encoding="utf-8"?>
<!-- S24 ULTRA - Tab-Based Professional DSP Interface -->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ultra_background">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/ultra_background"
        app:elevation="0dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="12dp"
                android:src="@drawable/ic_ultra_logo"
                android:contentDescription="DSP Ultra" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DSP ULTRA"
                    android:textColor="@color/ultra_primary"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.05" />

                <TextView
                    android:id="@+id/status_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="○ STANDBY"
                    android:textColor="@color/ultra_text_tertiary"
                    android:textSize="11sp" />

            </LinearLayout>

            <!-- Bluetooth indicator -->
            <LinearLayout
                android:id="@+id/bluetooth_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:visibility="gone"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:background="@drawable/bg_chip">

                <TextView
                    android:id="@+id/bluetooth_device_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="XM5"
                    android:textColor="@color/ultra_info"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/bluetooth_codec"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="LDAC"
                    android:textColor="@color/ultra_primary"
                    android:textSize="10sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Tab Layout -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tab_layout"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@color/ultra_background"
            app:tabMode="fixed"
            app:tabGravity="fill"
            app:tabIndicatorColor="@color/ultra_primary"
            app:tabIndicatorHeight="3dp"
            app:tabIndicatorFullWidth="false"
            app:tabSelectedTextColor="@color/ultra_primary"
            app:tabTextColor="@color/ultra_text_tertiary"
            app:tabTextAppearance="@style/UltraTabText"
            app:tabRippleColor="@color/ultra_primary_variant" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ViewPager for tabs -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/view_pager"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />

    <!-- Quick Toggle FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_dsp_toggle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        app:srcCompat="@drawable/ic_dsp_off"
        app:tint="@color/ultra_text_primary"
        app:backgroundTint="@color/ultra_glass_bg"
        app:borderWidth="2dp"
        app:elevation="8dp"
        app:fabSize="normal"
        android:contentDescription="Toggle DSP" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
