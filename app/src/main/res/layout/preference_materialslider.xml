<?xml version="1.0" encoding="utf-8"?>
<!-- S24 ULTRA - Material Slider Preference -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="start"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:baselineAligned="false"
    android:minHeight="64dp"
    android:paddingHorizontal="16dp"
    android:background="@color/ultra_glass_bg">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="12dp">
        <TextView
            android:id="@android:id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="marquee"
            android:singleLine="true"
            android:textColor="@color/ultra_text_secondary"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"/>
        <LinearLayout
            android:gravity="center_vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginStart="-4dp">
            <com.google.android.material.slider.Slider
                android:id="@+id/seekbar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:labelBehavior="floating"
                app:thumbColor="@color/ultra_primary"
                app:trackColorActive="@color/ultra_primary"
                app:trackColorInactive="@color/ultra_glass_border"
                app:haloColor="@color/ultra_primary_light"/>
            <TextView
                android:id="@+id/seekbar_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="56dp"
                android:ellipsize="marquee"
                android:gravity="end"
                android:scrollbars="none"
                android:fadingEdge="horizontal"
                android:singleLine="true"
                android:paddingStart="8dp"
                android:paddingEnd="0dp"
                android:textColor="@color/ultra_primary_light"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>