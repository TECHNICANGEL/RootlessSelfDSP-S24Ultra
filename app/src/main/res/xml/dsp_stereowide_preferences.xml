<?xml version="1.0" encoding="utf-8"?>
<!-- S24 ULTRA - Enhanced Stereo Widening Preferences -->
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <me.timschneeberger.rootlessjamesdsp.preference.SwitchPreferenceGroup
        android:key="@string/key_stereowide_enable"
        android:disableDependentsState="false"
        android:title="@string/stereowide_enable"
        android:icon="@drawable/ic_baseline_cone_24dp"
        app:iconSpaceReserved="false">

        <!-- Main Level -->
        <me.timschneeberger.rootlessjamesdsp.preference.MaterialSeekbarPreference
            android:title="@string/stereowide_level"
            android:key="@string/key_stereowide_mode"
            android:defaultValue="60"
            app:minValue="30"
            app:maxValue="75"
            app:allowDividerAbove="false"
            app:updatesContinuously="true"
            app:showSeekBarValue="true"
            app:iconSpaceReserved="false"/>

        <!-- Depth/Intensity -->
        <me.timschneeberger.rootlessjamesdsp.preference.MaterialSeekbarPreference
            android:key="@string/key_stereowide_depth"
            android:title="@string/stereowide_depth"
            android:summary="@string/stereowide_depth_summary"
            android:defaultValue="100"
            app:minValue="50"
            app:maxValue="300"
            app:unit="%"
            app:allowDividerAbove="false"
            app:updatesContinuously="true"
            app:showSeekBarValue="true"
            app:iconSpaceReserved="false"/>

        <!-- Center Preservation -->
        <me.timschneeberger.rootlessjamesdsp.preference.MaterialSeekbarPreference
            android:key="@string/key_stereowide_center"
            android:title="@string/stereowide_center"
            android:summary="@string/stereowide_center_summary"
            android:defaultValue="50"
            app:minValue="0"
            app:maxValue="100"
            app:unit="%"
            app:allowDividerAbove="false"
            app:updatesContinuously="true"
            app:showSeekBarValue="true"
            app:iconSpaceReserved="false"/>

        <!-- Bass Stereo Width -->
        <me.timschneeberger.rootlessjamesdsp.preference.MaterialSeekbarPreference
            android:key="@string/key_stereowide_low"
            android:title="@string/stereowide_low"
            android:summary="@string/stereowide_low_summary"
            android:defaultValue="30"
            app:minValue="0"
            app:maxValue="100"
            app:unit="%"
            app:allowDividerAbove="false"
            app:updatesContinuously="true"
            app:showSeekBarValue="true"
            app:iconSpaceReserved="false"/>

        <!-- Mid Stereo Width -->
        <me.timschneeberger.rootlessjamesdsp.preference.MaterialSeekbarPreference
            android:key="@string/key_stereowide_mid"
            android:title="@string/stereowide_mid"
            android:summary="@string/stereowide_mid_summary"
            android:defaultValue="100"
            app:minValue="0"
            app:maxValue="100"
            app:unit="%"
            app:allowDividerAbove="false"
            app:updatesContinuously="true"
            app:showSeekBarValue="true"
            app:iconSpaceReserved="false"/>

        <!-- High Stereo Width -->
        <me.timschneeberger.rootlessjamesdsp.preference.MaterialSeekbarPreference
            android:key="@string/key_stereowide_high"
            android:title="@string/stereowide_high"
            android:summary="@string/stereowide_high_summary"
            android:defaultValue="100"
            app:minValue="0"
            app:maxValue="100"
            app:unit="%"
            app:allowDividerAbove="false"
            app:updatesContinuously="true"
            app:showSeekBarValue="true"
            app:iconSpaceReserved="false"/>

    </me.timschneeberger.rootlessjamesdsp.preference.SwitchPreferenceGroup>
</PreferenceScreen>
